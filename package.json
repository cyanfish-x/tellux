{
  "name": "tellux",
  "version": "0.1.3",
  "description": "A Three.js GIS viewer for Cesium Ion 3D Tiles, atmosphere, clouds, and post-processing effects.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "README.en.md",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "vite build && tsc -p tsconfig.types.json",
    "build:examples": "vite build --config examples/vite.config.ts",
    "type-check": "tsc --noEmit",
    "clean": "rimraf dist",
    "dev": "vite examples --host 127.0.0.1 --port 5173 --strictPort",
    "deploy": "npm run build:examples && node actions/deploy.js",
    "prepublishOnly": "pnpm type-check && pnpm build",
    "release:check": "pnpm type-check && pnpm build && npm pack --dry-run",
    "release": "pnpm release:check && npm version patch -m \"发布 v%s\" && npm publish && git push --follow-tags"
  },
  "peerDependencies": {
    "3d-tiles-renderer": "^0.4.27",
    "@mapbox/vector-tile": "^2.0.3",
    "@takram/three-atmosphere": "0.19.1",
    "@takram/three-clouds": "0.7.6",
    "@takram/three-geospatial": "0.9.1",
    "@takram/three-geospatial-effects": "0.6.4",
    "pbf": "^4.0.1",
    "postprocessing": "6.39.1",
    "three": "^0.184.0"
  },
  "peerDependenciesMeta": {
    "@mapbox/vector-tile": {
      "optional": true
    },
    "pbf": {
      "optional": true
    }
  },
  "devDependencies": {
    "3d-tiles-renderer": "^0.4.27",
    "@mapbox/vector-tile": "^2.0.5",
    "@takram/three-atmosphere": "0.19.1",
    "@takram/three-clouds": "0.7.6",
    "@takram/three-geospatial": "0.9.1",
    "@takram/three-geospatial-effects": "0.6.4",
    "@types/node": "^18.18.12",
    "@types/three": "^0.184.1",
    "concurrently": "^9.2.1",
    "pbf": "^4.0.2",
    "postprocessing": "6.39.1",
    "rimraf": "^6.0.1",
    "three": "^0.184.0",
    "typescript": "~5.2.2",
    "vite": "^5.4.19"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "tencentcloud-sdk-nodejs-cdn": "^4.1.200"
  }
}
